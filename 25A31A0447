            printf("Enter value: ");
            scanf("%lf", &a);

            double rad = toRadians(a);

            if (op == 1) printf("sin = %.5lf\n", sin(rad));
            else if (op == 2) printf("cos = %.5lf\n", cos(rad));
            else if (op == 3) printf("tan = %.5lf\n", tan(rad));
            else printf("Invalid\n");
            break;
        }

        case 6: {
            int op;
            printf("1.log10 2.ln\n");
            scanf("%d", &op);
            printf("Enter value: ");
            scanf("%lf", &a);

            if (op == 1) printf("log = %.5lf\n", log10(a));
            else if (op == 2) printf("ln = %.5lf\n", log(a));
            else printf("Invalid\n");
            break;
        }

        case 7:
            printf("Enter base and exponent: ");
            scanf("%lf %lf", &a, &b);
            printf("Power = %.5lf\n", pow(a, b));
            printf("Square root of base = %.5lf\n", sqrt(a));
            break;

        case 8:
            printf("Enter integer: ");
            scanf("%d", &n);
            printf("Factorial = %lld\n", factorial(n));
            break;

        case 9:
            printf("Enter n and r: ");
            scanf("%d %d", &n, &r);
            printf("nPr = %lld\n", permutation(n, r));
            break;

        case 10:
            printf("Enter n and r: ");
            scanf("%d %d", &n, &r);
