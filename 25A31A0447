            scanf("%d", &op);

            if (op == 1) {
                printf("Enter value: ");
                scanf("%lf", &memory);
            } else if (op == 2) {
                printf("Enter value: ");
                scanf("%lf", &a);
                memory += a;
            } else if (op == 3) {
                printf("Enter value: ");
                scanf("%lf", &a);
                memory -= a;
            } else if (op == 4) {
                printf("Memory = %.5lf\n", memory);
            }
            break;
        }

        case 12:
            mode = !mode;
