# working-of-casio-calculator
#include <stdio.h>
#include <math.h>

#define PI 3.141592653589793

double memory = 0;
int mode = 0; // 0 = Degree, 1 = Radian

// Convert degree to radian if needed
double toRadians(double x) {
    if (mode == 0)
        return x * PI / 180;
    return x;
}

// Factorial function
long long factorial(int n) {
    if (n < 0) return -1;
    long long fact = 1;
    for (int i = 1; i <= n; i++)
        fact *= i;
    return fact;
}

// nCr
long long combination(int n, int r) {
    return factorial(n) / (factorial(r) * factorial(n - r));
}

// nPr
long long permutation(int n, int r) {
    return factorial(n) / factorial(n - r);
}

int main() {
    int choice;

    while (1) {
        printf("\n==== FX-991MS Advanced Calculator ====\n");
        printf("Mode: %s\n", mode == 0 ? "DEGREE" : "RADIAN");

        printf("1. Addition\n");
        printf("2. Subtraction\n");
        printf("3. Multiplication\n");
        printf("4. Division\n");
        printf("5. Trigonometric Functions\n");
        printf("6. Logarithmic Functions\n");
        printf("7. Power & Roots\n");
        printf("8. Factorial\n");
        printf("9. Permutation (nPr)\n");
        printf("10. Combination (nCr)\n");
        printf("11. Memory Operations\n");
        printf("12. Mode Switch (Deg/Rad)\n");
        printf("13. Extra Functions\n");
        printf("0. Exit\n");

        printf("Enter choice: ");
        scanf("%d", &choice);

        double a, b, result;
        int n, r;

        switch (choice) {

        case 1:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &a, &b);
            printf("Result = %.5lf\n", a + b);
            break;

        case 2:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &a, &b);
            printf("Result = %.5lf\n", a - b);
            break;

        case 3:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &a, &b);
            printf("Result = %.5lf\n", a * b);
            break;

        case 4:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &a, &b);
            if (b != 0)
